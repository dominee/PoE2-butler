        "title": "CharacterDetail"
      },
      "CharacterSummary": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "name": {
            "type": "string",
            "title": "Name"
          },
          "realm": {
            "type": "string",
            "title": "Realm",
            "default": "pc"
          },
          "class": {
            "type": "string",
            "title": "Class"
          },
          "level": {
            "type": "integer",
            "title": "Level",
            "default": 0
          },
          "league": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "League"
          },
          "experience": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Experience"
          }
        },
        "type": "object",
        "required": [
          "id",
          "name",
          "class"
        ],
        "title": "CharacterSummary"
      },
      "CharactersResponse": {
        "properties": {
          "league": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "League"
          },
          "characters": {
            "items": {
              "$ref": "#/components/schemas/CharacterSummary"
            },
            "type": "array",
            "title": "Characters"
          }
        },
        "type": "object",
        "required": [
          "league",
          "characters"
        ],
        "title": "CharactersResponse"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "Item": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "inventory_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Inventory Id"
          },
          "w": {
            "type": "integer",
            "title": "W",
            "default": 1
          },
          "h": {
            "type": "integer",
            "title": "H",
            "default": 1
          },
          "x": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "X"
          },
          "y": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Y"
          },
          "name": {
            "type": "string",
            "title": "Name",
            "default": ""
          },
          "type_line": {
            "type": "string",
            "title": "Type Line",
            "default": ""
          },
          "base_type": {
            "type": "string",
            "title": "Base Type",
            "default": ""
