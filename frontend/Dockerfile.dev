FROM node:22-alpine
WORKDIR /app

# Installed under /usr/local/bin so a bind mount of the repo to /app cannot strip +x
# (host copies of docker-entrypoint.dev.sh are often non-executable in git checkouts).
COPY docker-entrypoint.dev.sh /usr/local/bin/poe2b-frontend-dev-entrypoint.sh
RUN chmod +x /usr/local/bin/poe2b-frontend-dev-entrypoint.sh

COPY package.json package-lock.json* ./
RUN if [ -f package-lock.json ]; then npm ci; else npm install; fi

COPY . .
EXPOSE 5173
ENTRYPOINT ["/usr/local/bin/poe2b-frontend-dev-entrypoint.sh"]
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
