# -------- Environment --------
ENVIRONMENT=dev
LOG_LEVEL=INFO
PUBLIC_DOMAIN=hideoutbutler.com
APP_BASE_URL=http://app.hideoutbutler.com
API_BASE_URL=http://api.hideoutbutler.com

# Domains used by the prod compose file (see DEPLOY.md / GGG_API.md).
API_DOMAIN=api.hideoutbutler.com
APP_DOMAIN=app.hideoutbutler.com
ADMIN_DOMAIN=admin.hideoutbutler.com

# -------- Secrets (generate with: openssl rand -base64 32) --------
APP_SECRET_KEY=dev-only-change-me-dev-only-change-me-dev-only=
SESSION_SIGNING_KEY=dev-only-sign-me-dev-only-sign-me-dev-only-sig=

# -------- Postgres --------
POSTGRES_USER=poe2b
POSTGRES_PASSWORD=poe2b-dev-password
POSTGRES_DB=poe2b
DATABASE_URL=postgresql+asyncpg://poe2b:poe2b-dev-password@postgres:5432/poe2b

# -------- Redis --------
REDIS_URL=redis://redis:6379/0
REDIS_MAXMEMORY=128mb

# -------- GGG OAuth2 --------
# Internal hostname for server-to-server token/profile calls.
GGG_OAUTH_BASE_URL=http://ggg.hideoutbutler.com
GGG_API_BASE_URL=http://ggg.hideoutbutler.com
# Browser-facing authorize URL (leave empty in prod — same as GGG_OAUTH_BASE_URL).
# In dev override to the Traefik-routed hostname: http://ggg.hideoutbutler.com
GGG_OAUTH_AUTHORIZE_BASE_URL=
GGG_CLIENT_ID=poe2-butler-dev
GGG_CLIENT_SECRET=poe2-butler-dev-secret
# Prod: prefer app host: https://app.hideoutbutler.com/api/auth/callback (see GGG_API.md)
GGG_REDIRECT_URI=http://api.hideoutbutler.com/api/auth/callback
GGG_SCOPES=account:profile account:characters account:stashes account:leagues

# -------- CORS / frontend --------
CORS_ALLOW_ORIGINS=["http://app.hideoutbutler.com"]

# -------- Pricing (M4) --------
# Use "static" for offline/dev. Set to "poe_ninja" and configure the base URL
# once the community tracker for your league publishes a public API.
PRICING_SOURCE=static
PRICING_BASE_URL=https://poe.ninja/api/data
DEFAULT_VALUABLE_THRESHOLD_CHAOS=100

# -------- Admin (M5) --------
ADMIN_USERNAME=admin
# Generate a bcrypt hash with:
#   python -c 'import bcrypt; print(bcrypt.hashpw(b"yourpass", bcrypt.gensalt()).decode())'
# NOTE: bcrypt hashes contain '$' which docker compose interpolates. Escape
# each single '$' with '$$' when pasting into an env file consumed by compose
# --env-file (this example already uses $$).
ADMIN_PASSWORD_HASH=$$2b$$12$$kf1Sh4imysin12trFxWc6uhSuXCR4JUySGOwKgYR9Kn8y4obxEiYu
ADMIN_TOTP_SECRET=
ADMIN_SESSION_SECRET=dev-session-secret-change-me
ADMIN_IP_ALLOWLIST=[]

# UAT (mock GGG + public HTTPS): see deploy/env/.env.uat.example and DEPLOY.md §4.6.

# -------- Operations / contact (prod; optional) --------
# Used for runbooks and responsible disclosure; not read by the app.
SECURITY_CONTACT_EMAIL=ops@example.com

# -------- Container registry --------
GITHUB_OWNER=your-github-username
IMAGE_TAG=latest
