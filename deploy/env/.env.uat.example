# UAT: mock GGG + public HTTPS (Cloudflare → origin with Origin CA certificate).
# Copy to deploy/env/.env.uat and set secrets. See DEPLOY.md (UAT section).

# -------- Environment --------
ENVIRONMENT=uat
LOG_LEVEL=INFO
PUBLIC_DOMAIN=uat.hideoutbutler.com
# App host serves SPA and (via Traefik) /api on the same origin — like dev with Vite.
APP_BASE_URL=https://app.uat.hideoutbutler.com
API_BASE_URL=https://app.uat.hideoutbutler.com

# Not used by UAT compose (no Traefik Docker provider) — placeholder for parity.
API_DOMAIN=api.uat.hideoutbutler.com
APP_DOMAIN=app.uat.hideoutbutler.com
ADMIN_DOMAIN=admin.uat.hideoutbutler.com

# -------- Secrets (generate with: openssl rand -base64 32) --------
APP_SECRET_KEY=change-me-generate-with-openssl-rand-base64-32
SESSION_SIGNING_KEY=change-me-generate-with-openssl-rand-base64-32

# -------- Postgres (override in production UAT) --------
POSTGRES_USER=poe2b
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=poe2b
DATABASE_URL=postgresql+asyncpg://poe2b:change-me-strong@postgres:5432/poe2b

# -------- Redis --------
REDIS_URL=redis://redis:6379/0
REDIS_MAXMEMORY=128mb

# -------- GGG OAuth2 (mock) --------
# Overridden in docker-compose for server-to-server to mock-ggg:9000
GGG_OAUTH_BASE_URL=http://mock-ggg:9000
GGG_API_BASE_URL=http://mock-ggg:9000
# Browser: Traefik → mock-ggg; must be HTTPS in UAT
GGG_OAUTH_AUTHORIZE_BASE_URL=https://ggg.uat.hideoutbutler.com
GGG_CLIENT_ID=poe2-butler-dev
GGG_CLIENT_SECRET=poe2-butler-dev-secret
# Same app host as SPA; Traefik sends /api to the backend
GGG_REDIRECT_URI=https://app.uat.hideoutbutler.com/api/auth/callback
GGG_SCOPES=account:profile account:characters account:stashes account:leagues

# -------- CORS / frontend --------
CORS_ALLOW_ORIGINS=["https://app.uat.hideoutbutler.com"]

# -------- Pricing (M4) --------
PRICING_SOURCE=static
PRICING_BASE_URL=https://poe.ninja/api/data
DEFAULT_VALUABLE_THRESHOLD_CHAOS=100

# -------- Admin (M5) --------
ADMIN_USERNAME=admin
# python -c 'import bcrypt; print(bcrypt.hashpw(b"yourpass", bcrypt.gensalt()).decode())' — escape $ as $$ in compose
ADMIN_PASSWORD_HASH=$$2b$$12$$kf1Sh4imysin12trFxWc6uhSuXCR4JUySGOwKgYR9Kn8y4obxEiYu
ADMIN_TOTP_SECRET=
ADMIN_SESSION_SECRET=change-me
ADMIN_IP_ALLOWLIST=[]

# -------- Operations --------
SECURITY_CONTACT_EMAIL=ops@example.com

# -------- Optional: pre-built images (not required for local UAT) --------
GITHUB_OWNER=your-github-username
IMAGE_TAG=latest
